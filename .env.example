# Energy Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# Any connector left unconfigured will use placeholder data automatically.

# ---- General ----
PORT=3030
RATE_PER_KWH=0.13          # Your utility rate in $/kWh — check your Xcel bill

# ---- Xcel Itron Smart Meter (local network) ----
# Setup: npm run setup:xcel → follow printed instructions → enroll on xcelenergy.com
XCEL_METER_IP=             # e.g. 192.168.1.42  (find in router DHCP as "xcel-meter")
XCEL_METER_PORT=8081
XCEL_CERT_PATH=./certs/xcel.crt
XCEL_KEY_PATH=./certs/xcel.key

# ---- Emporia Vue (cloud API) ----
# Use same email/password as the Emporia app
EMPORIA_EMAIL=
EMPORIA_PASSWORD=
EMPORIA_TOKEN_FILE=./emporia_tokens.json   # tokens cached here after first login

# ---- APSystems EMA / Everlight Solar (cloud API) ----
# Find ECU ID in the EMA app: select your system → ECU ID shown at top
# OR: apsystemsema.com → login → your system → Settings → ECU Info
APSYSTEMS_ECU_ID=
